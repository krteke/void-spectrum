#[derive(Debug, Clone, PartialEq)]
pub struct ContractFileTheme {
    component FileButtonTokens {
        fg: spectrum_theme::Color,
        gap: spectrum_theme::Length,
    }

    file_button: FileButtonTokens,

    motion {
        delay: Delay,
        easing: Easing,
    }

    states button: FileButtonTokens {
        normal,
        hover extends normal,
        press_down extends hover,
    }
}
